# 複製這個檔成 .env，填入你的金鑰。.env 已被 .gitignore 排除，不會進 repo。

# ── 代理商模式（myai168 / NTHU）──────────────────────────
# 你的 64 字代理商金鑰（非 AIza 開頭）
GEMINI_API_KEY=
GEMINI_BASE_URL=https://www.myai168.com/nthu/api/google
GEMINI_USE_BEARER=true

# ── 或：Google 官方金鑰（改成直連時用）──────────────────
# GEMINI_API_KEY=AIza...
# 直連就把上面兩行 GEMINI_BASE_URL / GEMINI_USE_BEARER 註解掉或刪掉

# ── 模型（可換）──────────────────────────────────────────
# 標準文字對話 / 文字生圖（多模態）
TEXT_MODEL=gemini-3.1-pro-preview
IMAGE_MODEL=gemini-3-pro-image-preview

# ================= OpenAI（給 generate-openai.mjs 用）=================
OPENAI_API_KEY=
# 官方端點預設 https://api.openai.com/v1；要走 myai168 相容端點就設下一行：
# OPENAI_BASE_URL=https://www.myai168.com/nthu/api/openai/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
# 生圖品質：low（最快最便宜）/ medium / high / auto
OPENAI_IMAGE_QUALITY=low

# 允許跨網域前端呼叫本機後端（逗號分隔）
# 例如 GitHub Pages 前端 + 本機測試頁
CORS_ALLOW_ORIGINS=https://jong-liu.github.io,http://localhost:3000,http://127.0.0.1:3000

# 可選：課堂共用密碼（若有填，前端呼叫 API 需帶 X-App-Password）
APP_PASSWORD=
